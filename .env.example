# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL connection (configured in backend/src/main/resources/application.yml)
DB_URL=jdbc:postgresql://localhost:5432/student-tracker
DB_USERNAME=your_postgres_username
DB_PASSWORD=your_postgres_password

# ── Security ───────────────────────────────────────────────────────────────────
# JWT signing secret — use a long random hex string (min 32 bytes)
# Generate one with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here

# ── AI ─────────────────────────────────────────────────────────────────────────
# Claude API key from https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-...

# ── Setup instructions ─────────────────────────────────────────────────────────
# 1. Copy this file and rename it to application-secret.properties inside:
#    backend/src/main/resources/
#
# 2. Fill in the values above, then set these properties in that file:
#    spring.datasource.username=DB_USERNAME
#    spring.datasource.password=DB_PASSWORD
#    jwt.secret=JWT_SECRET
#    claude.api.key=CLAUDE_API_KEY
#
# 3. The application-secret.properties file is gitignored — never commit it.
